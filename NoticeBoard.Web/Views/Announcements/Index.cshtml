@model IEnumerable<NoticeBoard.Web.Models.AnnouncementViewModel>

@{
    ViewData["Title"] = "Оголошення";
}

<h1>Дошка оголошень</h1>

<form method="get" asp-action="Index" class="mb-4 d-flex align-items-center gap-2">
    <label for="category" class="form-label mb-0">Категорія:</label>
    <select name="category" id="category" class="form-select w-auto">
        <option value="">Усі категорії</option>
        @foreach (var cat in ViewBag.Categories as List<string>)
        {
            if (cat == ViewBag.SelectedCategory)
            {
                <option value="@cat" selected>@cat</option>
            }
            else
            {
                <option value="@cat">@cat</option>
            }
        }
    </select>
    <button type="submit" class="btn btn-primary">Фільтрувати</button>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">Створити нове оголошення</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Заголовок</th>
            <th>Категорія</th>
            <th>Підкатегорія</th>
            <th>Статус</th>
            <th>Дата створення</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center">Оголошень не знайдено.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Category</td>
                    <td>@item.SubCategory</td>
                    <td>
                        <span class="badge @(item.Status ? "bg-success" : "bg-secondary")">
                            @(item.Status ? "Активне" : "Неактивне")
                        </span>
                    </td>
                    <td>@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Редагувати</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
